{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-os Reflection Proposal Report",
  "type": "object",
  "required": ["report_date", "analysis_period", "sessions_analyzed", "proposals", "statistics"],
  "properties": {
    "report_date": {
      "type": "string",
      "format": "date",
      "description": "YYYY-MM-DD when the report was generated"
    },
    "analysis_period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "sessions_analyzed": {
      "type": "integer",
      "minimum": 0
    },
    "hook_events_analyzed": {
      "type": "integer",
      "minimum": 0
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "category", "title", "description", "evidence", "proposed_change", "estimated_weekly_savings_minutes"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^P[0-9]{3}$",
            "description": "Sequential ID: P001, P002, ..."
          },
          "priority": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "category": {
            "type": "string",
            "enum": [
              "CLAUDE_MD_RULE",
              "PROJECT_RULE",
              "CLAUDE_MD_REFINEMENT",
              "RULE_RELAXATION",
              "STALE_RULE_REVIEW",
              "SKILL_CREATION",
              "MEMORY_UPDATE",
              "EXPERIENCE_LEARNING"
            ]
          },
          "title": {
            "type": "string",
            "maxLength": 120
          },
          "description": {
            "type": "string",
            "minLength": 50
          },
          "evidence": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" },
            "description": "At least 2 distinct sessions or hook log entries supporting this proposal"
          },
          "proposed_change": {
            "type": "object",
            "required": ["file", "action"],
            "properties": {
              "file": { "type": "string", "description": "Absolute path to target file" },
              "action": {
                "type": "string",
                "enum": ["ADD_RULE", "UPDATE_RULE_RATIONALE", "ADD_EXCEPTION", "DELETE_RULE", "CREATE_SKILL", "UPDATE_SECTION", "CREATE_PATH_SCOPED_RULE", "APPEND_LEARNING"]
              },
              "scope": {
                "type": "string",
                "enum": ["user", "project", "path-scoped"],
                "description": "user-level (~/.claude/), project-level (repo/.claude/), or path-scoped (with paths: frontmatter)"
              },
              "paths": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Required when scope=path-scoped. Glob patterns."
              },
              "content": {
                "type": "string",
                "description": "Exact text to add or full replacement"
              },
              "rationale": {
                "type": "string",
                "description": "For UPDATE_RULE_RATIONALE: the new rationale explaining WHY the rule exists"
              }
            }
          },
          "impact": {
            "type": "string",
            "description": "Human-readable expected impact"
          },
          "estimated_weekly_savings_minutes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 600
          },
          "agent_sentiment": {
            "type": "string",
            "enum": ["apologetic", "confused", "compliant", "frustrated", "n/a"],
            "description": "From blocked-command analysis: how does the agent react to this rule?"
          },
          "grade": {
            "type": "object",
            "description": "Populated by grade-proposal skill after generation",
            "properties": {
              "score": { "type": "number", "minimum": 0, "maximum": 100 },
              "evidence_strength": { "type": "number", "minimum": 0, "maximum": 30 },
              "actionability": { "type": "number", "minimum": 0, "maximum": 25 },
              "impact_estimate": { "type": "number", "minimum": 0, "maximum": 15 },
              "reversibility": { "type": "number", "minimum": 0, "maximum": 15 },
              "scope_isolation": { "type": "number", "minimum": 0, "maximum": 15 },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "avg_session_duration_minutes": { "type": "number" },
        "median_human_interrupts": { "type": "number" },
        "most_used_repository": { "type": "string" },
        "blocked_commands_total": { "type": "integer" },
        "blocked_commands_by_rule": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "stale_rules_count": { "type": "integer" },
        "top_friction_points": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
