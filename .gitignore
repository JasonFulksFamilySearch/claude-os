# Belt and suspenders — data must NEVER end up in this repo
../.claude-data/
.claude-data/

# Environment / secrets — never commit
.env
.env.*
*.key
*.pem
secrets/
credentials/

# Anything that smells like a token
*token*
*secret*
*credentials*

# Claude Code scratch files (plans, tasks — not portable system code)
.claude/

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Python (for Phase 2+)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Node (in case any tooling shows up)
node_modules/
package-lock.json
mcp/package-lock.json

# Logs
*.log

# Generated skill output (data artifacts, not system code)
skills/daily-action/plans/

# Machine-local config (generated from *.template.json by install.sh)
config/watched-projects.json
config/episodes.json

# Override user-global ignore that masks the tracked docs/ directory
!docs/
!docs/**
